# Copy this file to .env and fill in your values before running docker-compose.
#
# Generate a password hash:
#   python3 -c "import hashlib; print(hashlib.sha256(b'yourpassword').hexdigest())"
#
# ── Single account ────────────────────────────────────────────────────────────
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=your_sha256_hash_here

# ── Two accounts (comma-separated, order must match) ─────────────────────────
# AUTH_USERNAMES=alice,bob
# AUTH_PASSWORD_HASHES=<hash_for_alice>,<hash_for_bob>
